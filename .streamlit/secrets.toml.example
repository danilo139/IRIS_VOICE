# ============================================================
# Voice Generator Panel — secrets.toml template
# Copy this file as  .streamlit/secrets.toml  and fill in your
# real values.  NEVER commit secrets.toml to version control.
# ============================================================

# ---------- ElevenLabs API ----------
[elevenlabs]
api_key   = "sk_your_elevenlabs_api_key_here"
voice_id  = "your_cloned_voice_id_here"

# ---------- OpenRouter API (Prompt Enhancer) ----------
[openrouter]
api_key = "sk-or-your_openrouter_api_key_here"

# ---------- App Users ----------
# Roles: "chatter", "manager", "ceo"

[users.chatter1]
password = "change_me_1"
role     = "chatter"

[users.chatter2]
password = "change_me_2"
role     = "chatter"

[users.chatter3]
password = "change_me_3"
role     = "chatter"

[users.chatter4]
password = "change_me_4"
role     = "chatter"

[users.Manager_Laila]
password = "change_me_mgr"
role     = "manager"

[users.Danilo_CEO]
password = "change_me_ceo"
role     = "ceo"

# ---------- Google Sheets Connection (Service Account) ----------
# Required for logging generations and reading the admin dashboard.
# Create a service account in Google Cloud Console, enable
# Google Drive API + Google Sheets API, then paste the JSON key
# fields below.  Share your Google Sheet with the client_email.

[connections.gsheets]
spreadsheet = "https://docs.google.com/spreadsheets/d/YOUR_SPREADSHEET_ID/edit"
worksheet   = "0"
type        = "service_account"
project_id  = ""
private_key_id = ""
private_key = ""
client_email = ""
client_id   = ""
auth_uri    = "https://accounts.google.com/o/oauth2/auth"
token_uri   = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = ""
